# Porta para a API de upload e scripts
HOST_PORT=8080

# Porta para visualizar a página Web
HOST_PORT_WEB=80

# Configurações internas
CONTAINER_PORT=5000

# Caminhos no Hospedeiro
UPLOAD_DIR_HOST=./from_sensors
DOWNLOAD_DIR_HOST=./maps
MATRIX_DIR_HOST=./matrixes

# Caminhos dentro do Container
UPLOAD_DIR_CONTAINER=/app/uploads
DOWNLOAD_DIR_CONTAINER=/app/downloads
MATRIX_DIR_CONTAINER=/app/matrixes